# ============================================
# AI PROVIDER SELECTION
# ============================================
# Choose: "openai" (testing) or "claude" (production)
AI_PROVIDER=openai

# ============================================
# OPENAI API (https://platform.openai.com)
# ============================================
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx
# Models: gpt-4o-mini (cheap), gpt-4o (best), gpt-4-turbo
OPENAI_MODEL=gpt-4o-mini

# ============================================
# CLAUDE API (https://console.anthropic.com)
# ============================================
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-6

# ============================================
# WORDPRESS SITE
# ============================================
WP_URL=https://your-test-site.com
WP_USERNAME=admin
# Application Password from: Users > Profile > Application Passwords
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ============================================
# BOT SETTINGS
# ============================================
ARTICLES_PER_DAY=1
DAILY_RUN_TIME=06:00
# 'publish' or 'draft'
POST_STATUS=draft
DEFAULT_CATEGORY=0
DEFAULT_AUTHOR=1

# ============================================
# CONTENT SETTINGS
# ============================================
SITE_NICHE=group buy seo tools, premium AI tools, digital marketing tools
SITE_NAME=GroupBuyServices
# 'en', 'bn', or 'mixed'
SITE_LANGUAGE=en
ARTICLE_WORD_COUNT=1800
# 'professional', 'casual', 'friendly', 'expert'
ARTICLE_TONE=expert
