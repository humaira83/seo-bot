# ============================================
# CLAUDE API (https://console.anthropic.com)
# ============================================
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-6

# ============================================
# WORDPRESS SITE
# ============================================
# Test site URL (later will be your Laravel API)
WP_URL=https://your-test-site.com
# WordPress username
WP_USERNAME=admin
# Application Password (Users > Profile > Application Passwords)
# NOT your regular WordPress password!
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ============================================
# BOT SETTINGS
# ============================================
# Articles per day (1-5)
ARTICLES_PER_DAY=1

# Time to run daily (24h format, server time)
DAILY_RUN_TIME=06:00

# Article post status: 'publish' or 'draft'
POST_STATUS=publish

# Default category ID (0 = uncategorized)
DEFAULT_CATEGORY=0

# Author user ID
DEFAULT_AUTHOR=1

# ============================================
# CONTENT SETTINGS
# ============================================
# Site niche/topic (used for keyword research)
SITE_NICHE=group buy seo tools, premium AI tools, digital marketing tools

# Site name (used in articles)
SITE_NAME=GroupBuyServices

# Site language: 'en', 'bn', or 'mixed'
SITE_LANGUAGE=en

# Article length (target word count)
ARTICLE_WORD_COUNT=1800

# Tone: 'professional', 'casual', 'friendly', 'expert'
ARTICLE_TONE=expert

# ============================================
# OPTIONAL: HUMANIZATION (later phase)
# ============================================
# QUILLBOT_API_KEY=
# HIX_BYPASS_API_KEY=

# ============================================
# OPTIONAL: KEYWORD RESEARCH (later phase)  
# ============================================
# Free Google Suggest is used by default
# DATAFORSEO_LOGIN=
# DATAFORSEO_PASSWORD=
